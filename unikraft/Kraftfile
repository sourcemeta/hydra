specification: v0.6
name: sourcemeta_hydra_test

unikraft:
  version: stable

rootfs: ../build/unikraft/rootfs

targets:
  - name: development
    platform: qemu
    architecture: x86_64
    kconfig:
      - CONFIG_LIBVFSCORE=y
      - CONFIG_LIBVFSCORE_AUTOMOUNT_CI1_DEV_ARG="initrd0"
      - CONFIG_LIBVFSCORE_AUTOMOUNT_CI_INITRD=y
      - CONFIG_LIBVFSCORE_AUTOMOUNT_CI=y
      - CONFIG_LIBVFSCORE_AUTOMOUNT_UP=y
      - CONFIG_LIBVFSCORE_AUTOMOUNT=y

libraries:
  ukp-bin:
    source: https://github.com/unikraft-io/lib-ukp-bin.git
    version: stable
    kconfig:
      - CONFIG_LIBUKP_DEPS=y
  libcxxabi:
    version: stable
  libcxx:
    version: stable
  libunwind:
    version: stable
  compiler-rt:
    version: stable
  musl:
    version: stable
  openssl:
    version: stable
    kconfig:
      - CONFIG_LIBOPENSSL=y
      - CONFIG_LIBSSL=y
  lwip:
    version: stable
    kconfig:
      - CONFIG_LIBLWIP=y
      - CONFIG_LWIP_UKNETDEV=y
      - CONFIG_LWIP_DHCP=y
      - CONFIG_LWIP_DNS=y
      # Fail if no network interface was provided
      - CONFIG_LWIP_FAILNOIFACE=y
  zlib:
    version: stable
    kconfig:
      - CONFIG_LIBZLIB=y
  curl:
    version: staging
    kconfig:
      - CONFIG_LIBCURL=y
      - CONFIG_LIBCURL_SSL=y
      - CONFIG_LIBCURL_ZLIB=y
      - CONFIG_LIBCURL_HTTP=y
      - CONFIG_LIBCURL_VERBOSE_STRINGS=y
  googletest:
    version: stable
    kconfig:
      - CONFIG_LIBGOOGLETEST=y
      - CONFIG_LIBGOOGLETEST_BUILD_MAIN=y
  hydra:
    source: ..
    kconfig:
      - CONFIG_LIBHYDRA=y
