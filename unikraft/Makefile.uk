$(eval $(call addlib,sourcemeta_hydra_test))

SOURCEMETA_HYDRA_TEST_CXXFLAGS-y += --std=c++20
SOURCEMETA_HYDRA_TEST_CXXFLAGS-y += -DBASE_URL=\"http://localhost:9999\"
TEST_BASE := $(SOURCEMETA_HYDRA_TEST_BASE)/../test

# HTTP
SOURCEMETA_HYDRA_TEST_SRCS-y += $(TEST_BASE)/http/request_1_1_test.cc
SOURCEMETA_HYDRA_TEST_SRCS-y += $(TEST_BASE)/http/stream_1_1_test.cc
